<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PDFReader.Pages.PasswordPromptPage"
             BackgroundColor="#99000000">

    <!-- Modal propio en lugar de DisplayPromptAsync: MAUI no permite enmascarar el texto ahi,
         y una contrasena a la vista en la pantalla no es aceptable. -->
    <Border Style="{StaticResource Card}"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            Margin="24"
            MaximumWidthRequest="420">

        <VerticalStackLayout Padding="20" Spacing="14">

            <Label x:Name="TitleLabel"
                   Style="{StaticResource BodyText}"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label x:Name="MessageLabel"
                   Style="{StaticResource SecondaryText}" />

            <Entry x:Name="PasswordEntry"
                   IsPassword="True"
                   ReturnType="Go"
                   Completed="OnAcceptClicked" />

            <Label x:Name="ErrorLabel"
                   Style="{StaticResource SecondaryText}"
                   TextColor="{StaticResource PdfPrimary}"
                   IsVisible="False" />

            <HorizontalStackLayout HorizontalOptions="End" Spacing="8">

                <Button x:Name="CancelButton"
                        Clicked="OnCancelClicked" />

                <Button x:Name="AcceptButton"
                        Clicked="OnAcceptClicked" />

            </HorizontalStackLayout>

        </VerticalStackLayout>
    </Border>
</ContentPage>
