<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Paleta de la aplicacion. Rojo PDF como color de marca, superficies neutras. -->
    <Color x:Key="PdfPrimary">#B3121E</Color>
    <Color x:Key="PdfPrimaryDark">#8A0E17</Color>
    <Color x:Key="PdfAccent">#E67E22</Color>
    <Color x:Key="PdfLegal">#E74C3C</Color>

    <Color x:Key="PdfPageBackgroundLight">#F2F3F5</Color>
    <Color x:Key="PdfPageBackgroundDark">#121212</Color>
    <Color x:Key="PdfSurfaceLight">#FFFFFF</Color>
    <Color x:Key="PdfSurfaceDark">#1E1E20</Color>
    <Color x:Key="PdfCanvasLight">#DEDFE3</Color>
    <Color x:Key="PdfCanvasDark">#0A0A0A</Color>
    <Color x:Key="PdfBorderLight">#E3E5E9</Color>
    <Color x:Key="PdfBorderDark">#2E2F33</Color>

    <Color x:Key="PdfTextPrimaryLight">#1F2430</Color>
    <Color x:Key="PdfTextPrimaryDark">#F2F3F5</Color>
    <Color x:Key="PdfTextSecondaryLight">#6B7280</Color>
    <Color x:Key="PdfTextSecondaryDark">#9CA3AF</Color>

    <!-- Superficies -->
    <Style x:Key="AppPage" TargetType="ContentPage">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource PdfPageBackgroundLight}, Dark={StaticResource PdfPageBackgroundDark}}" />
    </Style>

    <Style x:Key="Card" TargetType="Border">
        <Setter Property="BackgroundColor"
                Value="{AppThemeBinding Light={StaticResource PdfSurfaceLight}, Dark={StaticResource PdfSurfaceDark}}" />
        <Setter Property="Stroke"
                Value="{AppThemeBinding Light={StaticResource PdfBorderLight}, Dark={StaticResource PdfBorderDark}}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="StrokeShape">
            <Setter.Value>
                <RoundRectangle CornerRadius="14" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Texto -->
    <Style x:Key="CardTitle" TargetType="Label">
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource PdfTextPrimaryLight}, Dark={StaticResource PdfTextPrimaryDark}}" />
    </Style>

    <Style x:Key="BodyText" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.4" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource PdfTextPrimaryLight}, Dark={StaticResource PdfTextPrimaryDark}}" />
    </Style>

    <Style x:Key="SecondaryText" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource PdfTextSecondaryLight}, Dark={StaticResource PdfTextSecondaryDark}}" />
    </Style>

    <!-- Botones -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PdfPrimary}" />
        <Setter Property="TextColor" Value="#FFFFFF" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.4" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="OutlineButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource PdfPrimary}" />
        <Setter Property="BorderColor" Value="{StaticResource PdfPrimary}" />
        <Setter Property="BorderWidth" Value="1" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="HeightRequest" Value="46" />
    </Style>

    <!--
        Barra inferior del lector. Estos estilos llevan x:Key, asi que no heredan el estilo
        implicito de Button de la plantilla: el estado deshabilitado hay que declararlo aqui
        o los botones inactivos se verian igual que los activos.
    -->
    <Style x:Key="ReaderToolButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor"
                Value="{AppThemeBinding Light={StaticResource PdfTextPrimaryLight}, Dark={StaticResource PdfTextPrimaryDark}}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="WidthRequest" Value="48" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="24" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="1" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="Opacity" Value="0.25" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

</ResourceDictionary>
