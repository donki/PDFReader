<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!--
        Paleta unica de la aplicacion, con nombres semanticos (por rol, sin prefijo de app:
        el diccionario ya delimita el ambito). Rojo PDF como color de marca, superficies neutras.
        Todo color de superficie o de texto se declara por pares claro/oscuro y se consume con
        AppThemeBinding (constitucion, seccion 24).
        Nota Android: ver tambien Platforms\Android\Resources\values\colors.xml.
    -->

    <!-- Marca -->
    <Color x:Key="Primary">#B3121E</Color>
    <Color x:Key="PrimaryDark">#8A0E17</Color>
    <Color x:Key="Accent">#E67E22</Color>

    <!-- Estado -->
    <Color x:Key="Legal">#E74C3C</Color>

    <!-- Superficies -->
    <Color x:Key="PageBackgroundLight">#F2F3F5</Color>
    <Color x:Key="PageBackgroundDark">#121212</Color>
    <Color x:Key="SurfaceLight">#FFFFFF</Color>
    <Color x:Key="SurfaceDark">#1E1E20</Color>
    <Color x:Key="CanvasLight">#DEDFE3</Color>
    <Color x:Key="CanvasDark">#0A0A0A</Color>
    <Color x:Key="BorderLight">#E3E5E9</Color>
    <Color x:Key="BorderDark">#2E2F33</Color>

    <!-- Texto -->
    <Color x:Key="TextPrimaryLight">#1F2430</Color>
    <Color x:Key="TextPrimaryDark">#F2F3F5</Color>
    <Color x:Key="TextSecondaryLight">#6B7280</Color>
    <Color x:Key="TextSecondaryDark">#9CA3AF</Color>

    <!-- Neutros -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
</ResourceDictionary>
